<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/header', { pageTitle, appName }) %>
</head>
<body>
  <a class="skip-link" href="#main-content">Skip to content</a>

  <header class="site-header">
    <div class="container nav-bar">
      <a class="brand" href="/" aria-label="Manikanta Farms home">
        <span class="brand-mark">MF</span>
        <span class="brand-text">
          <strong><%= appName %></strong>
          <small>Fresh fruits & vegetables</small>
        </span>
      </a>

      <nav class="nav-links" aria-label="Primary">
        <a href="#products">Products</a>
        <a href="#about">About</a>
        <a href="#contact">Contact</a>
        <button class="theme-toggle" type="button" data-theme-toggle aria-label="Toggle theme">
          <span class="theme-toggle-icon">◐</span>
        </button>
      </nav>
    </div>
  </header>

  <main id="main-content">
    <section class="hero-section">
      <div class="hero-overlay"></div>
      <div class="container hero-content">
        <div class="hero-copy">
          <p class="eyebrow"><%= hero.eyebrow %></p>
          <h1><%= hero.title %></h1>
          <p class="hero-description"><%= hero.description %></p>

          <div class="hero-actions">
            <a class="btn btn-primary" href="#products">Shop fresh produce</a>
            <a class="btn btn-secondary" href="#about">Discover our farms</a>
          </div>

          <div class="trust-strip">
            <% trustPoints.forEach((point) => { %>
              <span><%= point %></span>
            <% }) %>
          </div>
        </div>
      </div>
    </section>

    <section id="products" class="products-section">
      <div class="container section-intro">
        <p class="section-label">Featured collection</p>
        <h2>Freshly selected for everyday quality</h2>
        <p>Explore premium fruits and vegetables sourced from trusted farms and chosen for freshness, appearance, and taste.</p>
      </div>

      <div class="container product-grid">
        <% products.forEach((product) => { %>
          <article class="product-card">
            <div class="product-image-wrap">
              <img
                src="<%= product.image %>"
                alt="<%= product.name %>"
                class="product-image"
                loading="lazy"
              />
            </div>

            <div class="product-content">
              <div class="product-topline">
                <span class="product-category"><%= product.category %></span>
                <span class="product-price"><%= product.pricePerUnit %></span>
              </div>

              <h3><%= product.name %></h3>
              <p class="product-description"><%= product.description %></p>

              <div class="product-origin">
                <span>Origin</span>
                <strong><%= product.origin %></strong>
              </div>
            </div>
          </article>
        <% }) %>
      </div>
    </section>

    <section id="about" class="about-section">
      <div class="container about-grid">
        <div class="about-image-card">
          <img
            src="https://images.unsplash.com/photo-1501004318641-b39e6451bec6?auto=format&fit=crop&w=1200&q=80"
            alt="Fresh green farm field"
            loading="lazy"
          />
        </div>

        <div class="about-content">
          <p class="section-label">About Manikanta Farms</p>
          <h2><%= story.title %></h2>
          <p><%= story.description %></p>

          <div class="feature-list">
            <% features.forEach((feature) => { %>
              <article class="feature-item">
                <h3><%= feature.title %></h3>
                <p><%= feature.description %></p>
              </article>
            <% }) %>
          </div>
        </div>
      </div>
    </section>

    <section class="testimonial-section">
      <div class="container section-intro">
        <p class="section-label">Customer trust</p>
        <h2>What customers say about us</h2>
      </div>

      <div class="container testimonial-grid">
        <% testimonials.forEach((item) => { %>
          <article class="testimonial-card">
            <p class="testimonial-quote">“<%= item.quote %>”</p>
            <h3><%= item.name %></h3>
            <span><%= item.role %></span>
          </article>
        <% }) %>
      </div>
    </section>
  </main>

  <%- include('partials/footer', { company }) %>
</body>
</html>
