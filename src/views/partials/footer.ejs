<footer id="contact" class="site-footer">
  <div class="container footer-grid">
    <div>
      <h2>Manikanta Farms</h2>
      <p>Fresh fruits and vegetables sourced from trusted farms with care, consistency, and premium quality.</p>
    </div>

    <div>
      <h3>Contact us</h3>
      <ul role="list" class="footer-list">
        <li><a href="tel:<%= company.phone.replace(/\s+/g, '') %>"><%= company.phone %></a></li>
        <li><a href="mailto:<%= company.email %>"><%= company.email %></a></li>
        <li><span><%= company.location %></span></li>
      </ul>
    </div>

    <div>
      <h3>Business hours</h3>
      <ul role="list" class="footer-list">
        <li>Monday - Saturday</li>
        <li>7:00 AM - 8:00 PM</li>
        <li>Fresh arrivals daily</li>
      </ul>
    </div>
  </div>
</footer>
