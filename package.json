{
  "name": "manikanta-farms",
  "version": "1.0.0",
  "description": "Premium farm business website built with Node.js, Express, and EJS for DevOps practice.",
  "main": "src/server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "lint": "eslint .",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "docker:build": "docker build -t manikanta-farms:local .",
    "docker:run": "docker run -p 3000:3000 --env-file .env manikanta-farms:local"
  },
  "keywords": [
    "nodejs",
    "express",
    "ejs",
    "kubernetes",
    "helm",
    "devops"
  ],
  "author": "Manikanta Reddy",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "ejs": "^3.1.10",
    "express": "^4.21.2",
    "helmet": "^8.1.0",
    "morgan": "^1.10.0"
  },
  "devDependencies": {
    "eslint": "^9.29.0",
    "@eslint/js": "^9.29.0",
    "globals": "^15.15.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.10",
    "supertest": "^7.1.1"
  },
  "jest": {
    "testEnvironment": "node"
  }
}
